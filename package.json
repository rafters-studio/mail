{
  "name": "rafters-mail-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run --config vitest.config.ts",
    "test:spec": "vitest run --config vitest.browser.config.ts",
    "test:e2e": "playwright test",
    "test:all": "pnpm test && pnpm test:spec && pnpm test:e2e",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@rafters/mail": "workspace:*",
    "@rafters/mail-drizzle": "workspace:*",
    "@rafters/mail-resend": "workspace:*",
    "@rafters/mail-workers-ai": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/browser": "^4.1.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "catalog:",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "playwright": "^1.58.2",
    "tsup": "^8.5.1",
    "uuidv7": "^1.1.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.25.0"
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
