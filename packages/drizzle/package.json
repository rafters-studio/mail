{
  "name": "@rafters/mail-drizzle",
  "version": "0.0.1",
  "description": "Drizzle ORM adapter for @rafters/mail. Table definitions and service implementations.",
  "license": "MIT",
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./tables": "./dist/tables.js",
    "./newsletter": "./dist/newsletter.js",
    "./services": "./dist/services/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "drizzle-orm": "catalog:",
    "uuidv7": "^1.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "better-sqlite3": "^12.8.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  }
}
