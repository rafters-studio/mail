{
  "name": "@rafters/mail-imap",
  "version": "0.1.0",
  "description": "IMAP4rev1 protocol layer for @rafters/mail. Transport-agnostic command handlers and adapter interfaces.",
  "homepage": "https://github.com/rafters-studio/mail/tree/main/packages/imap#readme",
  "bugs": {
    "url": "https://github.com/rafters-studio/mail/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafters-studio/mail.git",
    "directory": "packages/imap"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./protocol/parser": "./dist/protocol/parser.js",
    "./protocol/formatter": "./dist/protocol/formatter.js",
    "./session": "./dist/session.js",
    "./uid-map": "./dist/uid-map.js",
    "./flags": "./dist/flags.js",
    "./commands/auth": "./dist/commands/auth.js",
    "./commands/mailbox": "./dist/commands/mailbox.js",
    "./commands/message": "./dist/commands/message.js",
    "./commands/session": "./dist/commands/session.js",
    "./commands/extensions": "./dist/commands/extensions.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  }
}
