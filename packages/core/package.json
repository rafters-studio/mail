{
  "name": "@rafters/mail",
  "version": "0.1.0",
  "description": "Email inbox framework for the edge. Schema, types, service interfaces, threading logic.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafters-studio/mail.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/rafters-studio/mail/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/rafters-studio/mail/issues"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js",
    "./interfaces": "./dist/interfaces/index.js",
    "./threading": "./dist/threading.js",
    "./auth": "./dist/auth.js",
    "./migrations": "./dist/migrations/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "uuidv7": "^1.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  }
}
