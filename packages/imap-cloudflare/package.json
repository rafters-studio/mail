    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail-imap": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.0.0"
  }
}
