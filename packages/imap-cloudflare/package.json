{
  "name": "@rafters/mail-imap-cloudflare",
  "version": "0.1.0",
  "description": "Cloudflare Durable Object runtime adapter for @rafters/mail-imap",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafters-studio/mail.git",
    "directory": "packages/imap-cloudflare"
  },
  "homepage": "https://github.com/rafters-studio/mail/tree/main/packages/imap-cloudflare#readme",
  "bugs": {
    "url": "https://github.com/rafters-studio/mail/issues"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./do": "./dist/do.js",
    "./worker": "./dist/worker.js"
  },
  "publishConfig": {
