{
  "name": "@rafters/mail-workers-ai",
  "version": "0.1.0",
  "description": "Workers AI email classifier adapter for @rafters/mail",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafters-studio/mail.git",
    "directory": "packages/workers-ai"
  },
  "homepage": "https://github.com/rafters-studio/mail/tree/main/packages/workers-ai#readme",
  "bugs": {
    "url": "https://github.com/rafters-studio/mail/issues"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./config": "./dist/config.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  }
}
