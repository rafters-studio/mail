{
  "name": "@rafters/mail-cloudflare",
  "version": "0.0.1",
  "description": "Cloudflare Email Routing inbound adapter and R2 blob storage for @rafters/mail",
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./storage": "./src/r2-storage.ts",
    "./parsing": "./src/email-parsing.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  }
}
