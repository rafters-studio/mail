{
  "name": "@rafters/mail-cloudflare",
  "version": "0.0.1",
  "description": "Cloudflare Email Routing inbound adapter and R2 blob storage for @rafters/mail",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./storage": "./dist/r2-storage.js",
    "./parsing": "./dist/email-parsing.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  }
}
