{
  "name": "@rafters/mail-resend",
  "version": "0.1.0",
  "description": "Resend outbound email adapter for @rafters/mail",
  "license": "MIT",
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./mock": "./dist/mock-provider.js",
    "./webhooks": "./dist/webhook-handler.js",
    "./types": "./dist/resend-types.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "uuidv7": "^1.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  }
}
