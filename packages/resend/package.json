    "clean": "rm -rf coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zocker": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
