{
  "name": "@rafters/mail-resend",
  "version": "0.0.1",
  "description": "Resend outbound email adapter for @rafters/mail",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
