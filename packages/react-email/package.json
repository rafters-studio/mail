{
  "name": "@rafters/mail-react-email",
  "version": "0.0.1",
  "description": "React Email template renderer for @rafters/mail",
  "license": "MIT",
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./templates": "./dist/templates/base-email.js",
    "./otp": "./dist/templates/otp-email.js",
    "./renderer": "./dist/renderer.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail": "workspace:*",
    "@react-email/components": "^0.0.36",
    "react": "^19.2.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
