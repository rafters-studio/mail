{
  "name": "@rafters/mail-imap-server",
  "version": "0.1.0",
  "description": "Node TCP/TLS IMAP server runtime for @rafters/mail-imap",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafters-studio/mail.git",
    "directory": "packages/imap-server"
  },
  "homepage": "https://github.com/rafters-studio/mail/tree/main/packages/imap-server#readme",
  "bugs": {
    "url": "https://github.com/rafters-studio/mail/issues"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@rafters/mail-imap": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
